{
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": "npm install",
    "watchPatterns": [
      "package*.json",
      "index.js",
      "public/**"
    ]
  },
  "deploy": {
    "startCommand": "node index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}