{
  "name": "manager-pro",
  "version": "1.0.0",
  "description": "Sistema de Punto de Venta para Negocios Locales",
  "main": "index.js",
  "bin": "index.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "scripts": {
    "start": "node index.js",
    "build": "node build.js",
    "dev": "nodemon index.js",
    "pkg": "pkg . --targets node18-win-x64 --output dist/ManagerPro.exe"
  },
  "keywords": [
    "punto-de-venta",
    "pos",
    "negocio-local",
    "ventas"
  ],
  "author": "Julian Veegas",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "body-parser": "^1.20.2", 
    "express": "^4.18.2",     
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}